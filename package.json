{
    "name": "agentos",
    "version": "2.0.0",
    "description": "Enterprise-grade AI Agent Orchestration Cockpit",
    "main": "dist/main/index.js",
    "author": "AgentOS Team",
    "license": "MIT",
    "private": true,
    "scripts": {
        "dev": "npm run build:main && concurrently -k -n MAIN,VITE,ELECTRON -c blue,green,yellow \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron\"",
        "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
        "dev:renderer": "vite",
        "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
        "build": "npm run build:main && npm run build:renderer",
        "build:main": "tsc -p tsconfig.main.json",
        "build:renderer": "vite build",
        "dist": "npm run build && electron-builder",
        "dist:mac": "npm run build && electron-builder --mac",
        "dist:win": "npm run build && electron-builder --win",
        "dist:linux": "npm run build && electron-builder --linux",
        "dist:all": "npm run build && electron-builder -mwl",
        "lint": "eslint src --ext .ts,.tsx",
        "lint:fix": "eslint src --ext .ts,.tsx --fix",
        "typecheck": "tsc -p tsconfig.main.json --noEmit && echo 'Main OK'",
        "test": "cross-env NODE_ENV=test jest --coverage",
        "rebuild": "npx electron-rebuild"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.24.0",
        "@google/generative-ai": "^0.5.0",
        "@lancedb/lancedb": "^0.27.1",
        "bcryptjs": "^2.4.3",
        "better-sqlite3": "^9.4.3",
        "chokidar": "^3.6.0",
        "date-fns": "^3.3.1",
        "diff": "^5.2.0",
        "electron-store": "^8.2.0",
        "electron-updater": "^6.1.8",
        "eventemitter3": "^5.0.1",
        "express": "^4.18.2",
        "fast-glob": "^3.3.2",
        "fuse.js": "^7.0.0",
        "immer": "^10.0.4",
        "jsonwebtoken": "^9.0.2",
        "node-pty": "^1.0.0",
        "openai": "^4.40.0",
        "simple-git": "^3.22.0",
        "socket.io": "^4.7.4",
        "socket.io-client": "^4.7.4",
        "uuid": "^9.0.0",
        "winston": "^3.11.0",
        "yaml": "^2.4.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@monaco-editor/react": "^4.6.0",
        "@testing-library/react": "^15.0.7",
        "@types/bcryptjs": "^2.4.6",
        "@types/better-sqlite3": "^7.6.10",
        "@types/diff": "^5.2.1",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/node": "^20.12.7",
        "@types/react": "^18.3.1",
        "@types/react-dom": "^18.3.0",
        "@types/uuid": "^9.0.8",
        "@typescript-eslint/eslint-plugin": "^7.7.0",
        "@typescript-eslint/parser": "^7.7.0",
        "@vitejs/plugin-react": "^4.2.1",
        "@xterm/addon-fit": "^0.10.0",
        "@xterm/addon-search": "^0.15.0",
        "@xterm/addon-web-links": "^0.11.0",
        "@xterm/xterm": "^5.3.0",
        "autoprefixer": "^10.4.19",
        "clsx": "^2.1.0",
        "concurrently": "^8.2.2",
        "cross-env": "^7.0.3",
        "electron": "^30.0.0",
        "electron-builder": "^24.13.3",
        "eslint": "^8.57.0",
        "eslint-plugin-react-hooks": "^4.6.2",
        "eslint-plugin-react-refresh": "^0.4.6",
        "framer-motion": "^11.1.0",
        "jest": "^29.7.0",
        "lucide-react": "^0.378.0",
        "postcss": "^8.4.38",
        "react": "^18.3.0",
        "react-dom": "^18.3.0",
        "react-router-dom": "^6.23.0",
        "reactflow": "^11.11.1",
        "tailwind-merge": "^2.3.0",
        "tailwindcss": "^3.4.3",
        "ts-jest": "^29.1.2",
        "typescript": "^5.4.5",
        "vite": "^5.2.0",
        "wait-on": "^7.2.0",
        "zustand": "^4.5.2"
    },
    "build": {
        "appId": "com.agentos.app",
        "productName": "AgentOS",
        "asar": true,
        "asarUnpack": [
            "**/node_modules/node-pty/**",
            "**/node_modules/better-sqlite3/**"
        ],
        "directories": {
            "buildResources": "assets",
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "assets/**/*",
            "package.json"
        ],
        "mac": {
            "category": "public.app-category.developer-tools",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "identity": null,
            "gatekeeperAssess": false,
            "icon": "assets/icons/icon.icns",
            "hardenedRuntime": true,
            "entitlements": "build/entitlements.mac.plist",
            "entitlementsInherit": "build/entitlements.mac.plist"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "icon": "assets/icons/icon.ico",
            "certificateFile": null
        },
        "linux": {
            "target": [
                {
                    "target": "AppImage",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "deb",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icons/",
            "category": "Development"
        },
        "publish": [
            {
                "provider": "github",
                "owner": "agentos",
                "repo": "agentos"
            }
        ],
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    }
}
